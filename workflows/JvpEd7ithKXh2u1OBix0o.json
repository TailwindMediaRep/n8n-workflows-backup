      "name": "embeding"
    },
    {
      "parameters": {
        "jsCode": "const cohereOutput = $input.first().json;\nconst embedding = cohereOutput.embeddings.float[0];\n\nconst chunkData = $('dividir en chunks de 500').item.json;\n\n// Pausa de 2 segundos\nawait new Promise(resolve => setTimeout(resolve, 3000));\n\nreturn [{\n  json: {\n    content: chunkData.content,\n    metadata: chunkData.metadata,\n    embedding: embedding\n  }\n}];"
      },
