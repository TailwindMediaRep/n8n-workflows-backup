        ],
        "id": "9d5e1b50-6243-47bd-9abb-6ecc0e466774",
        "name": "Webhook",
        "webhookId": "94a058d3-1765-48d2-ab0c-68823e15508a"
      },
      {
        "parameters": {
          "jsCode": "// 1. Obtenemos el contenido de las dos columnas del Excel\nlet colecciones = $json[\"Aparece en las Colecciones\"] || \"\";\nlet generales = $json[\"Aparece en las Colecciones Generales\"] || \"\";\n\n// 2. Combinamos ambos textos en uno solo separado por el símbolo |\nlet textoCompleto = colecciones + \" | \" + generales;\n\n// 3. Dividimos el texto en etiquetas individuales usando el separador |\nlet listaCruda = textoCompleto.split('|');\n\n// 4. Aplicamos las reglas de limpieza:\nlet etiquetasLimpias = listaCruda.map(tag => {\n  return tag\n    .replace(/\\b(Hombre|Mujer|Niño|Niña|Niños|Niñas)\\b/gi, '') // 1. Quita Hombre, Mujer, etc.\n    .trim()                                                    // 2. Borra espacios al principio y final\n    .toLowerCase();                                            // 3. Todo a minúsculas\n});\n\n// 5. Eliminamos duplicados (ej: si \"Bolsos\" aparecía en ambas columnas) y etiquetas vacías\nlet resultadoFinal = [...new Set(etiquetasLimpias)].filter(t => t !== \"\");\n\n// 6. Enviamos el resultado al siguiente nodo incluyendo el ID del producto de Shopify\nreturn {\n  tagsToApply: resultadoFinal,\n  productId: $node[\"Webhook\"].json.body.admin_graphql_api_id\n};"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          -720,
          -1008
        ],
        "id": "ebf65859-297e-49b1-819d-7c74021890e7",
        "name": "Procesar Etiquetas"
      },
      {
        "parameters": {
          "authentication": "headerAuth",
          "endpoint": "https://rulesshop.myshopify.com/admin/api/2026-01/graphql.json",
          "query": "mutation tagsAdd($id: ID!, $tags: [String!]!) {\n  tagsAdd(id: $id, tags: $tags) {\n    node {\n      id\n    }\n    userErrors {\n      message\n    }\n  }\n}",
          "variables": "={\n  \"id\": \"{{ $json.productId }}\",\n  \"tags\": {{ JSON.stringify($json.tagsToApply || []) }}\n}"
        },
        "type": "n8n-nodes-base.graphql",
        "typeVersion": 1.1,
