      {
        "parameters": {
          "jsCode": "for (const item of $input.all()) {\n  try {\n    // 1. Verificamos que el QR se haya leído y tenga un enlace\n    const qrData = item.json.symbol[0];\n    \n    if (qrData && qrData.data) {\n      const url = qrData.data;\n      \n      // 2. Nos quedamos solo con la parte final de la URL (después de la última \"/\")\n      const codigoCodificado = url.split('/').pop();\n      \n      // 3. Traducimos ese trozo de Base64 a texto normal\n      const codigoSeguridad = Buffer.from(codigoCodificado, 'base64').toString('utf-8');\n      \n      // 4. Guardamos el resultado limpio\n      item.json.Codigo_Seguridad_Limpio = codigoSeguridad;\n    } else {\n      // Si no hay datos legibles en el QR\n      item.json.Codigo_Seguridad_Limpio = null;\n    }\n  } catch (error) {\n    // Si la imagen no tenía QR y la API devuelve algo inesperado\n    item.json.Codigo_Seguridad_Limpio = null;\n  }\n}\n\nreturn $input.all();"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          816,
          -112
        ],
        "id": "9fc2b3de-75f5-45f7-baeb-92f31903050e",
        "name": "Limpiar QR"
      },
      {
        "parameters": {
          "jsCode": "for (const item of $input.all()) {\n  try {\n    // 1. Extraemos el texto completo del JSON que nos ha devuelto OCR.space\n    const fullText = item.json.ParsedResults[0].ParsedText;\n\n    // 2. Buscamos la palabra \"seguridad\" seguida de espacios/saltos de línea y capturamos el código\n    const regexSeguridad = /seguridad[\\s\\r\\n]+([A-Z0-9]+)/i;\n    const matchSeguridad = fullText.match(regexSeguridad);\n    \n    // 3. Buscamos la palabra \"cupón\" (incluso si la lee como cupön) y capturamos el código con guiones\n    const regexCupon = /cup[óöo]n[\\s\\r\\n]+([A-Z0-9\\-]+)/i;\n    const matchCupon = fullText.match(regexCupon);\n\n    // 4. Guardamos los resultados limpios\n    item.json.Codigo_Seguridad_OCR = matchSeguridad ? matchSeguridad[1].trim() : null;\n    item.json.Codigo_Cupon_OCR = matchCupon ? matchCupon[1].trim() : null;\n    \n    // Opcional: Borramos el texto largo para que tu salida quede más limpia\n    delete item.json.ParsedResults;\n    delete item.json.OCRExitCode;\n    \n  } catch (error) {\n    // Por si alguna vez la imagen está borrosa y falla, que el workflow no se rompa\n    item.json.Codigo_Seguridad_OCR = null;\n    item.json.Codigo_Cupon_OCR = null;\n  }\n}\n\nreturn $input.all();"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          816,
          112
        ],
        "id": "c2a3eab5-3818-4863-a6e9-519ab8fe314e",
        "name": "Limpiar Texto"
